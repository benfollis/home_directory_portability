// ZONE B: TRANSIENT (Ignore)
(?i).cache
(?i)**/[Cc]ache
(?i)**/[Cc]aches
.local/share/Trash
.thumbnails
(?i)Videos
node_modules
**/target
**/build
.git/objects/pack
.git/index.lock

// ZONE C: STRICT IGNORE (Machine-Specific)
.config/syncthing
.local/state/syncthing
.local/share/syncthing
.config/monitors.xml
.config/pulse
.config/dconf/user
.config/google-chrome
.config/chromium
.Xauthority
.ICEauthority
.nvidia-settings-rc
.local/share/xorg

// HIGH CHURN / LOCK FILES
*.log
*.swp
*.lock
.DS_Store
